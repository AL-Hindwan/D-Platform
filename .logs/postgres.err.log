2026-05-31 00:02:05.922 +03 [24352] ERROR:  syntax error at or near "﻿" at character 1
2026-05-31 00:02:05.922 +03 [24352] STATEMENT:  ﻿-- Add enrollment rejected status and rejection metadata
	DO $$
	BEGIN
	  IF NOT EXISTS (
	    SELECT 1
	    FROM pg_enum e
	    JOIN pg_type t ON e.enumtypid = t.oid
	    WHERE t.typname = 'EnrollmentStatus' AND e.enumlabel = 'REJECTED'
	  ) THEN
	    ALTER TYPE "EnrollmentStatus" ADD VALUE 'REJECTED';
	  END IF;
	END $$;
	
	ALTER TABLE "enrollments"
	  ADD COLUMN IF NOT EXISTS "rejection_reason" TEXT,
	  ADD COLUMN IF NOT EXISTS "rejected_at" TIMESTAMP(3),
	  ADD COLUMN IF NOT EXISTS "rejected_by_id" TEXT;
	
	DO $$
	BEGIN
	  IF NOT EXISTS (
	    SELECT 1 FROM pg_constraint WHERE conname = 'enrollments_rejected_by_id_fkey'
	  ) THEN
	    ALTER TABLE "enrollments"
	      ADD CONSTRAINT "enrollments_rejected_by_id_fkey"
	      FOREIGN KEY ("rejected_by_id") REFERENCES "users"("id")
	      ON DELETE SET NULL ON UPDATE CASCADE;
	  END IF;
	END $$;
	
	CREATE INDEX IF NOT EXISTS "enrollments_rejected_by_id_idx" ON "enrollments"("rejected_by_id");
	
