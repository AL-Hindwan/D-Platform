# ─────────────────────────────────────────────
# Database (Render PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ─────────────────────────────────────────────
# JWT Secrets (use long random strings in production)
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET="CHANGE_ME_USE_A_LONG_RANDOM_STRING"
JWT_REFRESH_SECRET="CHANGE_ME_USE_ANOTHER_LONG_RANDOM_STRING"

JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────────
# Redis (optional — Render Redis or Upstash)
# ─────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV="production"

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# ─────────────────────────────────────────────
# CORS — your Vercel frontend URL
# ─────────────────────────────────────────────
FRONTEND_URL="https://your-app.vercel.app"

# ─────────────────────────────────────────────
# Email (Nodemailer / SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=منصة دال <your-email@gmail.com>

# ─────────────────────────────────────────────
# WhatsApp (Twilio) — optional
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─────────────────────────────────────────────
# Supabase Storage
# ─────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # service_role key (NOT anon key)

SUPABASE_IMAGES_BUCKET="images"
SUPABASE_FILES_BUCKET="files"
